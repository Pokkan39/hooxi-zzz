# Required — GitHub OAuth app
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# The exact callback URL registered in your GitHub OAuth app settings
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# GitHub repo that controls collaborator permissions
GITHUB_REPO_OWNER=Pokkan39
GITHUB_REPO_NAME=hooxi-zzz
GITHUB_BRANCH=main
# Public repo: public_repo read:user; private repo: repo read:user
OAUTH_SCOPE=public_repo read:user

# Randomly generated secret for HMAC session cookie signing (32+ chars recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_random_secret_min_32_chars

# Server
PORT=3001
NODE_ENV=development

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://pokkan39.github.io,http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Optional: absolute path to hooxi-zzz root (defaults to parent of backend/)
# SITE_ROOT=/path/to/hooxi-zzz

# Optional: custom session cookie name
# COOKIE_NAME=hooxi_session
