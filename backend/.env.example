# Required — 三账号安全登录配置
# 必须恰好 3 个账号（1 admin + 2 editor），id、name、password、role必填，id唯一，role为 admin 或 editor
# 密码必须是安全占位，例如 CHANGE_ME_ADMIN, CHANGE_ME_EDITOR_1, CHANGE_ME_EDITOR_2
EDITOR_ACCOUNTS_JSON=[{"id":"admin_user","name":"Administrator","password":"CHANGE_ME_ADMIN","role":"admin"},{"id":"editor_user1","name":"Editor One","password":"CHANGE_ME_EDITOR_1","role":"editor"},{"id":"editor_user2","name":"Editor Two","password":"CHANGE_ME_EDITOR_2","role":"editor"}]

# Randomly generated secret for HMAC session cookie signing (32+ chars recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_random_secret_min_32_chars

# Server
PORT=3001
NODE_ENV=development

# Session lifetime in seconds (optional, defaults to 43200 / 12 hours)
SESSION_TTL_SECONDS=43200

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://pokkan39.github.io,http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Optional: custom session cookie name
# COOKIE_NAME=hooxi_session

# GitHub review/publish integration — keep server-side only.
# Generate a fine-grained PAT with Contents read/write permission on the repo.
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Optional: absolute path to the site root for local file reading fallback.
# Defaults to the parent directory of backend/.
# SITE_ROOT=
